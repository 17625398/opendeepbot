# DeepTutor Environment Configuration Template
# ===========================================
# Copy this file to .env and fill in your values

# Server Configuration
BACKEND_PORT=8001
FRONTEND_PORT=3000

# LLM Configuration
# -----------------
# Supported bindings: openai, sglang, ollama, deepseek
LLM_BINDING=sglang
LLM_MODEL=qwen2:7b
LLM_API_KEY=your-api-key-here
LLM_HOST=http://localhost:8000/v1
LLM_API_VERSION=

# Embedding Configuration
# ----------------------
# Supported bindings: ollama, openai, sentence-transformers
EMBEDDING_BINDING=ollama
EMBEDDING_MODEL=qwen3-embedding:8b
EMBEDDING_API_KEY=your-api-key-here
EMBEDDING_HOST=http://localhost:11434/v1
EMBEDDING_DIMENSION=3072
EMBEDDING_API_VERSION=

# Search Configuration
# -------------------
SEARCH_PROVIDER=perplexity
SEARCH_API_KEY=your-search-api-key
SEARCH_PROXY=

# Hyper-Extract Configuration
# ---------------------------
HYPEREXTRACT_ENABLED=true
HYPEREXTRACT_LLM_PROVIDER=ollama
HYPEREXTRACT_LLM_MODEL=deepseek-chat
HYPEREXTRACT_BASE_URL=http://localhost:11434

# Cache Configuration
# -------------------
# Supported backends: memory, redis, sqlite
CACHE_BACKEND=memory
CACHE_TTL=3600
CACHE_MAX_SIZE=10000
REDIS_URL=redis://localhost:6379/0
SQLITE_CACHE_PATH=cache.db

# Telegram Channel Configuration
# ------------------------------
TELEGRAM_ENABLED=false
TELEGRAM_TOKEN=your-telegram-bot-token

# Discord Channel Configuration
# -----------------------------
DISCORD_ENABLED=false
DISCORD_TOKEN=your-discord-bot-token
DISCORD_PREFIX=!

# WeChat Channel Configuration
# ----------------------------
WECHAT_ENABLED=false
WECHAT_TOKEN=your-wechat-token

# Feishu Channel Configuration
# ----------------------------
FEISHU_ENABLED=false
FEISHU_APP_ID=your-feishu-app-id
FEISHU_APP_SECRET=your-feishu-app-secret

# Slack Channel Configuration
# ---------------------------
SLACK_ENABLED=false
SLACK_TOKEN=your-slack-token

# Email Channel Configuration
# ---------------------------
EMAIL_ENABLED=false
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=your-email@example.com
EMAIL_PASSWORD=your-email-password

# WebSocket Channel Configuration
# -------------------------------
WEBSOCKET_ENABLED=true
WEBSOCKET_PORT=8765

# QQ Channel Configuration (via Mirai)
# ------------------------------------
QQ_ENABLED=false
QQ_NUMBER=your-qq-number
QQ_MIRAI_URL=http://localhost:8080
QQ_VERIFY_KEY=your-mirai-verify-key

# Matrix Channel Configuration
# ----------------------------
MATRIX_ENABLED=false
MATRIX_HOMESERVER=https://matrix.org
MATRIX_USER_ID=@your-user:matrix.org
MATRIX_PASSWORD=your-matrix-password
MATRIX_ACCESS_TOKEN=your-matrix-access-token

# Agent Configuration
# -------------------
AGENT_MAX_ITERATIONS=10
AGENT_YOLO_MODE=false
AGENT_TRACK_COST=true

# Seafile Configuration
# ---------------------
SEAFILE_ENABLED=false
SEAFILE_SERVER_URL=http://localhost:8080
SEAFILE_API_URL=http://localhost:8080/api2
SEAFILE_USERNAME=your-seafile-username
SEAFILE_PASSWORD=your-seafile-password
SEAFILE_TOKEN=your-seafile-api-token
SEAFILE_DEFAULT_LIBRARY=DeepTutor
SEAFILE_UPLOAD_FOLDER=/
SEAFILE_TIMEOUT=30

# Knowledge Graph Configuration
# -----------------------------
# LLM settings for knowledge extraction
KG_LLM_PROVIDER=ollama
KG_LLM_MODEL=deepseek-chat
KG_LLM_API_KEY=
KG_LLM_BASE_URL=http://localhost:11434/v1
KG_OLLAMA_BASE_URL=http://localhost:11434

# Neo4j Configuration (for persistent graph storage)
KG_NEO4J_URI=bolt://localhost:7687
KG_NEO4J_USER=neo4j
KG_NEO4J_PASSWORD=your-neo4j-password

# Graph Storage Configuration
KG_STORAGE_BACKEND=memory
KG_DATA_DIR=./data/kg

# Extraction Configuration
KG_EXTRACTION_ENABLED=true
KG_EXTRACTION_TIMEOUT=120
KG_EXTRACTION_BATCH_SIZE=10

# Visualization Configuration
KG_VISUALIZATION_ENABLED=true
KG_VISUALIZATION_ENGINE=d3

# Logging Configuration
# ---------------------
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
