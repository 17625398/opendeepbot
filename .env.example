# DeepTutor Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# LLM Configuration
# =============================================================================

# Choose your LLM provider: openai, anthropic, deepseek, openrouter, ollama, vllm
LLM_PROVIDER=deepseek

# LLM API Key (if using cloud providers)
LLM_API_KEY=your-api-key-here

# LLM Model
LLM_MODEL=deepseek-chat

# LLM API Base URL (for custom endpoints like Ollama, vLLM, etc.)
LLM_BASE_URL=

# =============================================================================
# Ollama Configuration
# =============================================================================

# Enable Ollama
OLLAMA_ENABLED=false
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3

# =============================================================================
# Embedding Configuration
# =============================================================================

# Embedding provider: openai, anthropic, deepseek, ollama, huggingface
EMBEDDING_PROVIDER=deepseek
EMBEDDING_MODEL=deepseek-embedding
EMBEDDING_DIMENSION=1536

# =============================================================================
# Channels Configuration
# =============================================================================

# Telegram Bot
TELEGRAM_ENABLED=false
TELEGRAM_TOKEN=your-telegram-bot-token

# Discord Bot
DISCORD_ENABLED=false
DISCORD_TOKEN=your-discord-bot-token
DISCORD_PREFIX=!

# WebSocket Gateway
WEBSOCKET_ENABLED=true
WEBSOCKET_HOST=localhost
WEBSOCKET_PORT=8765

# =============================================================================
# Database Configuration
# =============================================================================

# Database type: sqlite, postgresql, mysql
DATABASE_TYPE=sqlite
DATABASE_URL=sqlite:///./deeptutor.db

# =============================================================================
# Memory Configuration
# =============================================================================

# Enable enhanced memory system
MEMORY_ENABLED=true
MEMORY_VECTOR_STORE=chromadb
MEMORY_CHROMA_URL=
MEMORY_PERSIST_PATH=./data/memory

# =============================================================================
# Agent Configuration
# =============================================================================

# Agent mode: normal, yolo, thinking
AGENT_MODE=normal

# Maximum iterations
AGENT_MAX_ITERATIONS=10

# Enable cost tracking
AGENT_TRACK_COST=true

# Enable workspace snapshots
AGENT_SNAPSHOTS=true

# =============================================================================
# WebUI Configuration
# =============================================================================

# WebUI settings
WEBUI_ENABLED=true
WEBUI_HOST=localhost
WEBUI_PORT=3782
WEBUI_URL=http://localhost:3782

# =============================================================================
# Logging Configuration
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
LOG_FILE=./logs/deeptutor.log

# =============================================================================
# MCP (Model Context Protocol) Configuration
# =============================================================================

# Enable MCP servers
MCP_ENABLED=true

# MCP servers config (JSON string or path to file)
# MCP_SERVERS={"servers":[{"name":"filesystem","command":"npx","args":["-y","@modelcontextprotocol/server-filesystem","/path/to/allowed/directory"]}]}

# =============================================================================
# Security Configuration
# =============================================================================

# Secret key for JWT and other security features
SECRET_KEY=your-secret-key-here-change-in-production

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3782

# =============================================================================
# Feature Flags
# =============================================================================

# Enable/disable specific features
ENABLE_ANALYTICS=true
ENABLE_HISTORY=true
ENABLE_STATISTICS=true